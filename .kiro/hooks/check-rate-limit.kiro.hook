{
  "hooks": [
    {
      "name": "Check Rate Limit Sleep",
      "description": "Ensures time.sleep(RATE_LIMIT_SLEEP) exists between consecutive LLM calls",
      "enabled": true,
      "when": {
        "type": "fileEdited",
        "patterns": [
          "agents/*.py",
          "core/*.py"
        ]
      },
      "instructions": "When any Python file in agents/ is saved, find every place where model.generate_content() is called. Check if there is a time.sleep() call BEFORE it in the same function. If another LLM call or agent function call precedes it without a sleep, add time.sleep(RATE_LIMIT_SLEEP) before the generate_content() call. Never add sleep before the very first LLM call in a function. Never change any logic. Only add missing sleep calls. Make sure RATE_LIMIT_SLEEP is imported from core.config at the top of the file if not already imported."
    }
  ]
}